validators/
# Exclude generated documentation
docs_build/
# Exclude test and dev files
tests/
# The production acceptance command uses exactly these source-controlled
# canaries. Keep the rest of the test suite out of the runtime image.
!tests/
tests/*
!tests/assets/
tests/assets/*
!tests/assets/fmu/
tests/assets/fmu/*
!tests/assets/fmu/Feedthrough.fmu
!tests/assets/idf/
tests/assets/idf/*
