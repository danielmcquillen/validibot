!tests/assets/schematron/calibration/calibration-rules-demo.sch
!tests/assets/schematron/calibration/calibration-certificate-valid.xml
*.md
README*
LICENSE*
# Exclude local data and caches
storage/
# Ship the small curated EnergyPlus weather catalogue used by
# initialize_validibot, while excluding any other developer-local data.
data/*
!data/weather/
!data/weather/**
.parcel-cache/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
# Exclude SCSS/TS source files (compiled output is already in static/)
validibot/static/src/
# Exclude build artifacts
dist/
build/
*.egg-info/
# Claude / AI config
CLAUDE.md
AGENTS.md
.claude/
.vscode/
# Overlay directory used by optional commercial-package builds. The
# Dockerfile reads these via the ``extras`` named context, not via
# the root build context, so excluding them here prevents the runtime
# stage's ``COPY . /app`` from shipping them into the final image.
_extra_packages/

# Sibling repo mount points, if present. The commercial package sources
# are read via --build-context at build time (see just/gcp/mod.just);
# any copies that land in the repo root — historically named
# ``_validibot-pro/`` or ``_validibot-cloud/``, or plain
# ``validibot-pro/`` / ``validibot-cloud/`` from other tooling — must
# stay out of the image.
_validibot-pro/
_validibot-cloud/
validibot-pro/
validibot-cloud/
validibot-enterprise/
