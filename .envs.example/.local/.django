# General
# ------------------------------------------------------------------------------
# Set to "yes" when running in Docker containers, "no" when running Django directly
# on your machine. Docker Compose uses "yes".
USE_DOCKER=yes
IPYTHONDIR=/app/.ipython

# Django Secret Key
# ------------------------------------------------------------------------------
# REQUIRED. Used by Django for cryptographic signing (sessions, password
# reset tokens, CSRF, signed cookies). The app will refuse to start if this
# is not set, even in local development.
#
# Generate a fresh one with:
#
#     python -c "import secrets; print(secrets.token_urlsafe(50))"
#
# NEVER reuse a secret key across deployments (dev / staging / prod should
# each have their own) and NEVER commit a real key to version control.
DJANGO_SECRET_KEY=!!!SET DJANGO_SECRET_KEY!!!

# Redis
# ------------------------------------------------------------------------------
# Redis URL for Celery task queue. In Docker Compose, "redis" is the container hostname.
REDIS_URL=redis://redis:6379/0

# Celery Flower (optional)
# ------------------------------------------------------------------------------
# Credentials for the Celery Flower monitoring UI (http://localhost:5555)
# Only needed if you want to monitor Celery tasks via the web UI.
# For local development, simple defaults are fine.
CELERY_FLOWER_USER=debug
CELERY_FLOWER_PASSWORD=debug

# Default Superuser
# ------------------------------------------------------------------------------
# Created automatically by the `setup_validibot` management command.
# Change these before running setup for the first time.
SUPERUSER_USERNAME=admin
SUPERUSER_PASSWORD=!!!SET SUPERUSER_PASSWORD!!!
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_NAME=Admin

# Email (optional)
# ------------------------------------------------------------------------------
# If not set, emails are printed to the console (useful for local development).
# To test actual email delivery, get a token from an email service provider.
# Postmark (recommended):
# POSTMARK_SERVER_TOKEN=your-postmark-server-token

# MFA
# ------------------------------------------------------------------------------
# Multi-factor authentication (authenticator apps + recovery codes).
#
# MFA_TOTP_ISSUER is the label shown in users' authenticator apps next to
# their account email. Replace the placeholder below with your company or
# deployment name (e.g. "Acme Corp Validibot Self-Hosted"). Leaving the
# placeholder will technically work but makes authenticator-app entries
# indistinguishable between deployments.
MFA_TOTP_ISSUER=your-mfa-issuer-name
#
# DJANGO_MFA_ENCRYPTION_KEY is REQUIRED. TOTP secrets and recovery-code
# seeds are stored encrypted in the database via Fernet (AES-128-CBC +
# HMAC-SHA256). The app will fail to start without this key.
#
# Generate a fresh key with:
#
#     python -c "from cryptography.fernet import Fernet; \
#         print(Fernet.generate_key().decode())"
#
# The output is a 44-character URL-safe base64 string ending in `=`.
# NEVER reuse a key across deployments (dev / staging / prod should each
# have their own). See docs/dev_docs/how-to/configure-mfa.md for rotation.
DJANGO_MFA_ENCRYPTION_KEY=!!!SET DJANGO_MFA_ENCRYPTION_KEY!!!
#
# These settings route admin login through allauth and require an enrolled,
# current MFA factor. They stay False locally so routine development and the
# test suite do not need an authenticator app. Turn both on when testing the
# hardened admin flow. Production defaults both to True.
DJANGO_ADMIN_FORCE_ALLAUTH=False
DJANGO_ADMIN_REQUIRE_MFA=False

# Feature Toggles
# ------------------------------------------------------------------------------
# Show the sign up page (set to false to disable new registrations)
DJANGO_ACCOUNT_ALLOW_REGISTRATION=true
# Allow users to log in (can be false while allowing existing users to stay logged in)
DJANGO_ACCOUNT_ALLOW_LOGIN=true

# Workflow Configuration
# ------------------------------------------------------------------------------
# How often (in seconds) the run-detail page polls for status updates via HTMX.
# Lower = more responsive UI but more server requests.
# Higher = fewer requests but slower feedback.
WORKFLOW_RUN_POLL_INTERVAL_SECONDS=3

# Validator backend image policy: tag, digest, or signed-digest.
# Local and local-cloud builds use mutable development tags by default.
VALIDATOR_BACKEND_IMAGE_POLICY=tag

# SHACL Validator
# ------------------------------------------------------------------------------
# Core SHACL validation is always on. Advanced SHACL-AF constructs —
# embedded SPARQL constraints and SHACL Rules — are disabled at the
# deployment level until you explicitly opt in. Only turn this on for
# trusted, isolated worker environments, since these constructs can run
# author-supplied SPARQL. (SHACL-JS is always rejected regardless.)
# Defaults to False, so leave this commented out unless you need it.
#SHACL_ENABLE_ADVANCED_FEATURES=False
#
# Resource limits guard the engine against oversized or malicious graphs.
# Each has a safe default and a hard cap enforced in engine code, so you
# only need to set these to tighten a deployment below the defaults. See
# validibot/validations/validators/shacl/engine.py for the full list
# (triple-count caps, validation depth, pySHACL/SPARQL timeouts).
#SHACL_MAX_DATA_TRIPLES=100000
#SHACL_VALIDATION_TIMEOUT_SECONDS=300

# SIGNUP ABUSE PROTECTIONS
# ==============================================================================
# Defaults are False. Some deployments (e.g. the hosted offering) flip
# these on to reject throwaway addresses and add a honeypot field to the
# signup form. Set to False explicitly during local dev if another
# settings module has enabled them and you want to sign up with a
# disposable address like test@mailinator.com.
#REJECT_DISPOSABLE_EMAILS=False
#USE_SIGNUP_HONEYPOT=False

# ==============================================================================
# ADD-ON CONFIGURATION  —  Pro / Enterprise
# ==============================================================================
# Everything ABOVE this line is community/core config that every local
# deployment uses. Everything below only matters when you run the local-pro /
# local-cloud stacks with a commercial tier installed — plain `just local` can
# ignore it. These settings are read by the community settings module but do
# nothing until validibot-pro supplies the backend that consumes them.

# Signed Credentials (Pro / Enterprise)
# ------------------------------------------------------------------------------
# Generate a local P-256 signing key if you want to issue signed credentials:
#   mkdir -p .envs/.local/keys
#   openssl ecparam -name prime256v1 -genkey -noout \
#     -out .envs/.local/keys/credential-signing.pem
#   chmod 600 .envs/.local/keys/credential-signing.pem
#
# The standard local Docker Compose stack mounts .envs/.local/keys into the
# containers at /run/validibot-keys. The separate local-cloud stack mounts the
# whole repo at /app, so use /app/.envs/.local/keys/... there instead.
SIGNING_KEY_PATH=
# Example:
# SIGNING_KEY_PATH=/run/validibot-keys/credential-signing.pem
#
# Optional explicit issuer URL for credential payloads. Leave empty to reuse
# SITE_URL when signing is enabled.
CREDENTIAL_ISSUER_URL=
# Optional override. ES256 is the only algorithm currently supported.
SIGNING_ALGORITHM=ES256

# MCP HELPER API SERVICE-TO-SERVICE AUTH
# ==============================================================================
# Paired local secret used by the FastMCP server to authenticate itself to
# Django when calling /api/v1/mcp/*. Generate one value and place it here and
# in .envs/.local/.mcp. Without this, MCP tool calls hit the helper API and get
# 401 on every request.
#
# Read by ``validibot.mcp_api.authentication.MCPServiceAuthentication``
# as ``settings.MCP_SERVICE_KEY``. In hosted cloud production, leave
# this empty — the auth class falls back to Cloud Run OIDC identity
# tokens instead.
#
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Uncomment and set this when running `local-pro`/`local-cloud` with
# ENABLE_MCP_SERVER=true. Plain `just local` has no MCP container, so it can
# stay commented there.
#VALIDIBOT_MCP_SERVICE_KEY=

# X402 AGENT PAYMENTS (cloud-only — local-cloud stack)
# ==============================================================================
# x402 is a cloud-only feature — read ONLY under
# DJANGO_SETTINGS_MODULE=validibot_cloud.settings.local (the community and
# local_pro settings do not verify x402). The MCP server no longer touches
# payments, so ALL x402 config lives here with its single consuming service —
# not in .build, which is no longer mounted into any app container. Used only
# when VALIDIBOT_X402_ENABLED=true, which in practice means `just local-cloud
# up` (plain `local-pro` has no cloud agent endpoint to receive paid launches).
#
# Enable + test/live switch.
#   VALIDIBOT_X402_ENABLED=true → anonymous paid validation is live.
#   VALIDIBOT_X402_TEST_MODE    → true = testnet (Base Sepolia), false = mainnet (Base).
VALIDIBOT_X402_ENABLED=false
VALIDIBOT_X402_TEST_MODE=true

# Testnet set (used when TEST_MODE=true) — Base Sepolia. The open x402.org
# facilitator needs no CDP auth, so a Sepolia rehearsal needs no CDP key below.
VALIDIBOT_TEST_X402_NETWORK=eip155:84532
VALIDIBOT_TEST_X402_ASSET=0x036cbd53842c5426634e7929541ec2318f3dcf7e
VALIDIBOT_TEST_X402_PAY_TO_ADDRESS=0xYOUR_BASE_SEPOLIA_WALLET
VALIDIBOT_TEST_X402_FACILITATOR_URL=https://x402.org/facilitator

# Mainnet set (used when TEST_MODE=false) — Base. The pay-to address is public
# (quoted in payment requirements); the private key never goes in any env file.
# Set the facilitator URL explicitly before enabling live x402 — the agent
# endpoint refuses to settle without it.
VALIDIBOT_X402_NETWORK=eip155:8453
VALIDIBOT_X402_ASSET=0x833589fcd6edb6e08f4c7c32d4f71b54bda02913
VALIDIBOT_X402_PAY_TO_ADDRESS=0xYOUR_BASE_MAINNET_WALLET
VALIDIBOT_X402_FACILITATOR_URL=

# Coinbase CDP facilitator credentials (SECRET, mainnet only). The cloud
# agent-validate endpoint signs a short-lived bearer JWT with this CDP key on
# every /verify and /settle call. Leave blank for a Base Sepolia rehearsal.
#VALIDIBOT_X402_CDP_API_KEY_ID=
#VALIDIBOT_X402_CDP_API_KEY_SECRET=
