# Validibot MCP server — local Docker Compose development (example).
#
# Copy to .envs/.local/.mcp and fill in the values below. The `mcp`
# service defined by the MCP-enabled Compose profile reads this file
# when `ENABLE_MCP_SERVER=true just local-pro up` (or `just local-cloud
# up` for the full hosted stack) runs. The MCP server itself also
# requires a license that advertises the `mcp_server` feature — plain
# community deployments won't boot it.

# ── Core ───────────────────────────────────────────────────────────────

VALIDIBOT_MCP_ENABLED=true
VALIDIBOT_LOG_LEVEL=DEBUG

# Django web container URL inside the Compose network.
VALIDIBOT_API_BASE_URL=http://web:8000
VALIDIBOT_AGENT_API_BASE_URL=http://web:8000

# Public URL of this MCP server (port-mapped to 8001 locally). Local Django
# defaults to the same URL, so the OAuth token audience + RFC 9728 metadata
# line up unless you intentionally override both runtime files for OAuth tests.
VALIDIBOT_MCP_BASE_URL=http://localhost:8001

# Paired local secret. Generate one long random string and place it here and in
# .envs/.local/.django (uncomment the line there too). Django exposes that env
# var as the MCP_SERVICE_KEY setting. Mismatch -> 401 on every /api/v1/mcp/*
# call.
VALIDIBOT_MCP_SERVICE_KEY=replace-with-a-long-random-string

# ── OAuth ───────────────────────────────────────────────────────────────
# The authorization-server URL is REQUIRED (config.py has no default), even
# though local dev defaults to the legacy API-token path. Point it at the
# Django web container.
VALIDIBOT_OAUTH_AUTHORIZATION_SERVER_URL=http://web:8000
# The client credentials are OPTIONAL — leave the secret unset and the server
# uses the legacy API-token verifier. Set them only to exercise the Claude
# Desktop OAuth flow locally; the secret is a paired local secret with
# IDP_OIDC_MCP_SERVER_CLIENT_SECRET in .envs/.local/.django.
# VALIDIBOT_OAUTH_CLIENT_ID=validibot-mcp-server
# VALIDIBOT_OAUTH_CLIENT_SECRET=
# Validibot's standard authorize/token/revoke/JWKS paths are derived locally.
# Override the complete endpoint URLs only when testing compatible custom
# routing; see docs/dev_docs/deployment/environment-configuration.md.

# ── x402 payments ──────────────────────────────────────────────────────
#
# The MCP server no longer handles x402 payments. Anonymous agent payments
# moved to the cloud agent API (validibot-cloud), and the Coinbase CDP
# facilitator credentials now live in the cloud Django secret
# (.envs/.production/.google-cloud/.django), not here. The MCP server only
# serves authenticated, user-backed validation, so it needs no x402 config.
