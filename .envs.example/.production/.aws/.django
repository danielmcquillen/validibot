# Validibot AWS Configuration
# ==============================================================================
# Copy this file to .envs/.production/.aws/.django
# NOTE: AWS deployment is planned but not yet fully implemented.

# DJANGO
# ==============================================================================
DJANGO_SETTINGS_MODULE=config.settings.production
DEPLOYMENT_TARGET=aws
DJANGO_SECRET_KEY=your-secret-key-here-change-this
DJANGO_ALLOWED_HOSTS=validibot.example.com
# Generate a secret key with:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'

# MFA encryption key — REQUIRED in production. TOTP secrets and
# recovery-code seeds are stored encrypted via Fernet. The app refuses
# to start without this key. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Store in AWS Secrets Manager / Parameter Store. Never reuse the dev key.
DJANGO_MFA_ENCRYPTION_KEY=replace-with-generated-fernet-key

# MFA TOTP issuer — the label shown in users' authenticator apps.
MFA_TOTP_ISSUER=your-mfa-issuer-name

# DJANGO_ADMIN_FORCE_ALLAUTH routes Django's /admin/login/ through allauth
# so that admin sign-in enforces MFA (for users who've enrolled a second
# factor) plus allauth's rate limiting and session rotation. Without
# this, admin logs in via a plain Django form that bypasses allauth.
# Leave True in production. Flip to False only as a break-glass when
# allauth itself is broken — redeploy required. See
# docs/dev_docs/how-to/configure-mfa.md for the full recovery procedure.
DJANGO_ADMIN_FORCE_ALLAUTH=True

# DATABASE
# ==============================================================================
# RDS PostgreSQL connection (no separate postgres file for AWS)
POSTGRES_HOST=your-rds-instance.region.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_DB=validibot
POSTGRES_USER=validibot
POSTGRES_PASSWORD=change-this-password-in-production
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# REDIS
# ==============================================================================
# ElastiCache Redis endpoint
REDIS_URL=redis://your-elasticache-endpoint:6379/0

# STORAGE
# ==============================================================================
# AWS S3 for file storage
DATA_STORAGE_BACKEND=s3
AWS_S3_REGION_NAME=us-east-1
STORAGE_BUCKET=your-app-name-storage
#AWS_ACCESS_KEY_ID=your-access-key      # Optional if using IAM roles
#AWS_SECRET_ACCESS_KEY=your-secret-key  # Optional if using IAM roles

# SENTRY (optional)
# ==============================================================================
#SENTRY_DSN=https://your-sentry-dsn

# DEFAULT USERS
# ==============================================================================
# Initial superuser created on first run
SUPERUSER_USERNAME=admin
SUPERUSER_PASSWORD=change-this-password
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_NAME=Admin User

# EMAIL
# ==============================================================================
# If not configured, emails are logged to console.
# Choose ONE of the following email providers:
#
# AWS SES (native for AWS deployments):
#EMAIL_BACKEND=django_ses.SESBackend
#AWS_SES_REGION_NAME=us-east-1
#AWS_SES_REGION_ENDPOINT=email.us-east-1.amazonaws.com
#
# Postmark:
#POSTMARK_SERVER_TOKEN=your-postmark-server-token
#
# Mailgun:
#MAILGUN_API_KEY=your-mailgun-api-key
#MAILGUN_SENDER_DOMAIN=mg.yourdomain.com
#
# SendGrid:
#SENDGRID_API_KEY=your-sendgrid-api-key
#
# Generic SMTP:
#EMAIL_HOST=smtp.example.com
#EMAIL_PORT=587
#EMAIL_USE_TLS=true
#EMAIL_HOST_USER=your-smtp-user
#EMAIL_HOST_PASSWORD=your-smtp-password

# FEATURE TOGGLES
# ==============================================================================
# Registration and login
DJANGO_ACCOUNT_ALLOW_REGISTRATION=true
DJANGO_ACCOUNT_ALLOW_LOGIN=true

# URLS
# ==============================================================================
SITE_URL=https://validibot.example.com

# ADMIN
# ==============================================================================
# IMPORTANT: Change this to a random URL to prevent automated attacks on /admin/.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(16))"
# Example result: DJANGO_ADMIN_URL=k8Xm2pQ1wZ9nR4tB/
DJANGO_ADMIN_URL=admin/

# SSL redirect (set to false if ALB handles SSL)
DJANGO_SECURE_SSL_REDIRECT=true

# VALIDATOR CONTAINERS
# ==============================================================================
# Resource limits for advanced validator containers (ECS tasks)
VALIDATOR_MEMORY_LIMIT=4g
VALIDATOR_CPU_LIMIT=2.0

# SIGNUP ABUSE PROTECTIONS (community defaults; cloud layer overrides)
# ==============================================================================
# Both default False in community; cloud.py flips them on. Override here
# to explicitly force a value.
#REJECT_DISPOSABLE_EMAILS=False
#USE_SIGNUP_HONEYPOT=False

# RUNTIME LAUNCH VELOCITY LIMITS (cloud only)
# ==============================================================================
#LAUNCH_VELOCITY_PER_MINUTE=30
#LAUNCH_VELOCITY_PER_HOUR=500
