# =============================================================================
# Production GCP build + recipe configuration
# =============================================================================
#
# Copy this file to ``.envs/.production/.google-cloud/.build`` before
# your first ``just gcp deploy-all prod``. The ``just gcp`` module
# sources this file at the top of any recipe that needs deploy-time
# knobs — currently the MCP build/deploy step, the MCP API URL, and
# the MCP x402 public payment settings.
#
# Unlike the other files in this directory (``.django``, ``.mcp``,
# ``.just``), this file is NOT uploaded to GCP Secret Manager — it
# only affects local ``just`` behavior at deploy time. Values here
# become ``--set-env-vars`` on the Cloud Run service, so they do
# reach a running container, but as public env vars, not secrets.
#
# Keep this file private; the whole .envs/ tree is gitignored.
#
# Every knob here is REQUIRED if the corresponding recipe is invoked —
# there are no defaults that point at the hosted ``validibot.com``
# deployment, so a misconfigured self-hoster cannot accidentally
# proxy their users' traffic to someone else's API. Recipes fail
# with a loud error listing the missing variable.
# =============================================================================


# -- Recipe-level knobs ----------------------------------------------------

# ENABLE_MCP_SERVER
# -----------------
# Controls whether ``just gcp deploy-all <stage>`` builds and deploys
# the MCP Cloud Run service as part of the full deploy. When unset or
# false, deploy-all skips the MCP step silently (web + worker +
# scheduler still deploy as normal).
#
# Requires validibot-pro (or enterprise) to be installed in the
# deployment — the MCP server calls ``GET /api/v1/license/features/``
# at startup and refuses to boot if ``mcp_server`` isn't advertised.
# If you set this to true without Pro installed, the MCP Cloud Run
# service will deploy but fail its license check and 503 every request.
#
# Also read by the standalone ``just gcp mcp build`` / ``deploy``
# (and their legacy aliases ``just mcp build`` / ``deploy``) — the
# same knob controls both the unified deploy-all path and surgical
# MCP-only paths.
#
#   true   — include MCP build + deploy
#   false  — omit MCP (default)
ENABLE_MCP_SERVER=false

# VALIDIBOT_MCP_API_BASE_URL
# --------------------------
# Public URL of the Validibot Django API the MCP server should proxy
# tool calls to. Gets stamped into the MCP Cloud Run service as
# ``VALIDIBOT_API_BASE_URL`` at deploy time.
#
# Required when ENABLE_MCP_SERVER=true. There is no default — set this
# to YOUR Validibot deployment's hostname. Examples:
#
#   # validibot.com (hosted)
#   VALIDIBOT_MCP_API_BASE_URL=https://app.validibot.com
#
#   # your own self-hosted deployment
#   VALIDIBOT_MCP_API_BASE_URL=https://app.yourco.com
#
# This value must also match what the MCP service account has
# ``run.invoker`` on, since the MCP Cloud Run service authenticates
# to Django using a Cloud Run OIDC identity token issued for this
# audience. ``just gcp mcp setup`` wires that up automatically.
VALIDIBOT_MCP_API_BASE_URL=

# -- MCP x402 public config ----------------------------------------------

# These values are public deploy-time config for the MCP Cloud Run
# revision. They are deliberately kept out of ``.mcp`` because
# ``.mcp`` is uploaded to Secret Manager and should only hold actual
# secrets, such as receiving wallet addresses.
#
# Django still verifies the receipt independently. If you enable x402
# here, set the matching Django-side values in ``.django``:
#
#   X402_PAY_TO_ADDRESS=<same wallet MCP forwards>
#   X402_ALLOWED_NETWORK_ASSET_PAIRS=eip155:8453=0x833589fcd6edb6e08f4c7c32d4f71b54bda02913
#
# ENABLED
# -------
#   true   — anonymous x402 launches are available through /public-mcp
#   false  — anonymous launches remain payment-required/disabled
VALIDIBOT_X402_ENABLED=false

# TEST MODE
# ---------
# Keep false for Base mainnet. When true, MCP uses the
# VALIDIBOT_TEST_X402_PAY_TO_ADDRESS secret from .mcp and the built-in
# Base Sepolia public defaults from config.py. Django must still be
# configured with the matching testnet pay-to and allowed pair.
VALIDIBOT_X402_TEST_MODE=false

# NETWORK / ASSET
# ---------------
# Explicit pair the MCP server quotes. Django must list the same pair
# in X402_ALLOWED_NETWORK_ASSET_PAIRS or run creation fails closed.
VALIDIBOT_X402_NETWORK=eip155:8453
VALIDIBOT_X402_ASSET=0x833589fcd6edb6e08f4c7c32d4f71b54bda02913

# FACILITATOR
# -----------
# Endpoint the MCP server asks to verify and settle x402 payments.
VALIDIBOT_X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
