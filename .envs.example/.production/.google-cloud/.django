# Validibot GCP Configuration
# ==============================================================================
# Copy this file to .envs/.production/.google-cloud/.django
# This file is for Google Cloud Platform deployments (Cloud Run).
#
# Layout — the file is ordered in three tiers so you only read what applies:
#   1. COMMUNITY / CORE      — every deployment sets these (top of file)
#   2. ADD-ON CONFIGURATION  — Pro / Enterprise self-hosted add-ons
#   3. CLOUD-ONLY            — the hosted SaaS layer (very bottom)

# Environment identifier
VALIDIBOT_STAGE=prod

# DJANGO
# ==============================================================================
DJANGO_SETTINGS_MODULE=config.settings.production
DEPLOYMENT_TARGET=gcp
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=your-secret-key-here-change-this
DJANGO_API_KEY_DIGEST_KEY=replace-with-generated-api-key-digest-key
# IMPORTANT: Change to a random URL to prevent automated attacks on /admin/.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(16))"
DJANGO_ADMIN_URL=admin/
# Specific Cloud Run hostnames plus custom domain
# Security: Do NOT use wildcards like .run.app - that allows any Cloud Run service
DJANGO_ALLOWED_HOSTS=your-service-name.region.run.app,your-subdomain.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-subdomain.example.com
# Generate a secret key with:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
# Generate an API key digest key with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
# Keep it separate from DJANGO_SECRET_KEY.

# Production security headers (SECURE_PROXY_SSL_HEADER, SSL redirect, HSTS,
# secure cookies) are hardcoded in config/settings/production.py — they are
# NOT env-configurable, so there is nothing to set here.

# Trusted-proxy count for client-IP resolution in DRF throttles. DRF reads the
# real client IP from the Nth-from-last entry of X-Forwarded-For; the count must
# match how many proxies append to XFF in front of this service, or IP-keyed
# throttles (e.g. the anonymous x402 validate endpoint) misbehave — too low
# over-throttles all clients together, too high is spoofable. app.validibot.com
# runs behind the Google global external HTTPS load balancer, which appends two
# hops (real client + Google front end), so the real client is the SECOND from
# the right → 2. (A direct Cloud Run domain mapping would be 1; community
# default is 1.) VERIFY before trusting this — curl from a known IP and count
# from the right (see docs/dev_docs/deployment/reverse-proxy.md), then uncomment.
# Until set, the community default of 1 applies (safe direction: over-throttles
# rather than allowing a bypass). Stronger still: have the LB overwrite XFF with
# {client_ip_address} so spoofed prefixes never arrive — see the x402 ops runbook
# "Hardening: sanitize X-Forwarded-For at the load balancer".
#DRF_NUM_PROXIES=2

# DATABASE
# ==============================================================================
# Cloud SQL uses Unix socket connection via Cloud SQL Auth Proxy
# Format: postgres://USER:PASSWORD@/DATABASE?host=/cloudsql/CONNECTION_NAME
POSTGRES_DB=validibot
POSTGRES_USER=validibot_user
POSTGRES_PASSWORD=change-this-password
CLOUD_SQL_CONNECTION_NAME=your-project:region:your-instance

DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@/${POSTGRES_DB}?host=/cloudsql/${CLOUD_SQL_CONNECTION_NAME}

# CACHE (shared across workers + scaled instances)
# ==============================================================================
# Django's cache must be shared across Gunicorn workers and Cloud Run
# instances — allauth rate limiting and TOTP replay prevention depend
# on it. The GCP deployment uses Django's `DatabaseCache` backend by
# default (persisted in the existing Cloud SQL Postgres database);
# that's $0 incremental cost and fine for pre-release volume.
#
# Before the first deploy, run `python manage.py createcachetable` to
# provision the `django_cache` table. See the runbook for details.
#
# When traffic grows or latency becomes a concern, provision Memorystore
# for Redis, attach it via VPC connector, and uncomment REDIS_URL below.
# `config/settings/production.py` will switch to RedisCache automatically.
#REDIS_URL=redis://10.x.x.x:6379/0

# Cache key prefix — required when the Redis instance is shared with
# other environments (e.g. staging + prod behind the same managed
# Redis, or dev environments sharing a single Memorystore instance
# to save on cost). Django transparently prepends this to every
# cache key; without it, keys collide silently across environments
# and a staging org's plan mask can leak into production. Safe to
# leave unset when Redis is single-tenant to this deployment —
# Django will log a warning on boot if it looks risky.
#DJANGO_CACHE_KEY_PREFIX=prod

# LOGGING
# ==============================================================================
# Sentry error tracking (recommended for production)
#SENTRY_DSN=https://your-sentry-dsn

# STORAGE (GCS)
# ==============================================================================
# On Cloud Run, ADC uses the service account attached to the Cloud Run service.
# Locally, run `gcloud auth application-default login` first.
#
# Single bucket with prefix-based separation:
#   public/  - Public files (avatars, images) - configure IAM for allUsers read
#   private/ - Private files (submissions, validation data)
STORAGE_BUCKET=your-app-name-storage

# DEFAULT USERS
# ==============================================================================
# Initial superuser created on first run
SUPERUSER_USERNAME=admin
# YOU MUST ADD A PASSWORD BELOW, OTHERWISE THIS USER WILL NOT BE CREATED
SUPERUSER_PASSWORD=
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_NAME=Admin User

# EMAIL
# ==============================================================================
# From address for transactional emails. Change to your domain.
DJANGO_DEFAULT_FROM_EMAIL=MyCompanyValidibot <noreply@example.com>
# If not configured, emails are logged to console.
# Postmark (recommended):
#POSTMARK_SERVER_TOKEN=your-postmark-server-token

# SITE (Django Sites framework)
# ==============================================================================
# These seed the Django "Sites" framework row (the django_site table,
# SITE_ID=1). They are read — via os.environ, not the settings module — by
# the `setup_validibot` management command, which runs automatically on the
# first container start and on every `just gcp setup-site`. The command calls
# update_or_create(), so it re-asserts these values on each run (idempotent).
#
# Why they matter: get_current_site() reads this row to build absolute URLs
# in contexts that have no HTTP request to derive the host from —
# transactional emails, the help pages, and health checks. On a
# non-interactive deploy (`setup_validibot --noinput`, which is what GCP
# runs), an UNSET VALIDIBOT_SITE_DOMAIN silently falls back to
# "localhost:8000", which then poisons those absolute URLs in production. So
# always set it explicitly here.
#
# Note: this is the BARE HOST (no scheme), and is deliberately distinct from
# SITE_URL below. Keep the host portion of the two in agreement.
VALIDIBOT_SITE_DOMAIN=validibot.example.com
# Human-readable display name for this deployment. Defaults to "Validibot"
# when unset; override if you white-label the instance.
VALIDIBOT_SITE_NAME=Validibot

# URLS
# ==============================================================================
# SITE_URL is the full public ORIGIN (scheme + host). It is used for
# validator callbacks, the issuer URL embedded in signed credentials
# (CREDENTIAL_ISSUER_URL defaults to it), and the API server metadata. This
# is distinct from VALIDIBOT_SITE_DOMAIN above (the bare host stored in the
# Sites framework) — keep the host portion of the two in sync.
SITE_URL=https://validibot.example.com
WORKER_URL=https://your-worker-service.region.run.app

# GCP
# ==============================================================================
# Resource names follow the pattern: {GCP_APP_NAME}-{resource}[-{stage}]
# where GCP_APP_NAME is set in .envs/.production/.google-cloud/.just
GCP_PROJECT_ID=your-gcp-project-id
# Runtime region the app reads for cloud resources such as Cloud Tasks and GCS.
# Use the same deployment region chosen in .just for host-side GCP commands.
GCP_REGION=australia-southeast1

# Cloud Tasks
GCS_TASK_QUEUE_NAME=your-app-name-tasks
CLOUD_TASKS_SERVICE_ACCOUNT=your-app-name-cloudrun-prod@your-project.iam.gserviceaccount.com
# Separate long-delivery queue and OIDC identity for private validator Services.
GCP_VALIDATOR_TASK_QUEUE_NAME=your-app-name-validator-provider
GCP_VALIDATOR_TASK_INVOKER_SERVICE_ACCOUNT=your-app-name-val-invoker-prod@your-project.iam.gserviceaccount.com
GCP_VALIDATOR_TASK_DISPATCH_DEADLINE_SECONDS=1800
VALIDATOR_STATUS_LOOKUP_GRACE_SECONDS=300

# Worker-endpoint OIDC verification (validators, Cloud Tasks, Cloud Scheduler).
# See docs/dev_docs/deployment/environment-configuration.md and
# ADR-2026-04-18 for the full design.
#
# TASK_OIDC_AUDIENCE: Expected `aud` claim. Must equal the worker service
# URL origin (scheme + host, NO path). Cloud Tasks and Cloud Scheduler sign
# tokens with this exact value, and validator containers derive it from the
# callback URL's origin. If unset, Django falls back to WORKER_URL.
# Typical value (same as WORKER_URL above):
TASK_OIDC_AUDIENCE=https://your-worker-service.region.run.app
#
# TASK_OIDC_ALLOWED_SERVICE_ACCOUNTS: Comma-separated list of service
# account emails authorised to sign tokens for worker endpoints. EMPTY LIST
# MEANS REJECT EVERYTHING. Django raises ImproperlyConfigured on startup
# when DEPLOYMENT_TARGET=gcp and this list is empty. Include every SA that
# invokes the worker: the main Cloud Run SA (Cloud Tasks + Scheduler) and the
# validator runtime SA (Job/Service callbacks and capability renewal).
TASK_OIDC_ALLOWED_SERVICE_ACCOUNTS=your-app-name-cloudrun-prod@your-project.iam.gserviceaccount.com,your-app-name-validator-prod@your-project.iam.gserviceaccount.com

# Validation infrastructure (primary Cloud Run Services + retained Jobs)
# GCS_VALIDATION_BUCKET is the bucket validator runtimes stage run files in
# (gs://<bucket>/runs/<org_id>/<run_id>/). You do NOT set it on GCP:
# config/settings/production.py derives it from STORAGE_BUCKET inside the
# DEPLOYMENT_TARGET=gcp branch (`GCS_VALIDATION_BUCKET = STORAGE_BUCKET`), so any
# value placed here is overwritten and ignored. It is read from the environment
# ONLY on self-hosted Docker deployments that opt into GCS storage. Left
# commented here to document the relationship — STORAGE_BUCKET above is the one
# place this bucket is defined for a GCP deploy.
#GCS_VALIDATION_BUCKET=
GCS_WEATHER_DATA_DIR=weather_data
# TEST_ENERGYPLUS_WEATHER_FILE is a TEST/DEV-ONLY knob — the weather file used
# when exercising EnergyPlus validators outside production (integration tests,
# local smoke runs). A real deployment does not need it; left commented for
# discoverability. Default is in config/settings/base.py.
#TEST_ENERGYPLUS_WEATHER_FILE=USA_CA_San.Francisco.Intl.AP.724940_TMY3.epw
# Cloud Run job names are derived from the validator's slug
# (e.g. slug="energyplus" -> "validibot-validator-backend-energyplus").
# No per-validator env vars are required here.
# GCP storage authority is a fixed deployment contract: every attempt receives
# a prefix-bound token and the validator service account has no ambient object
# role. Image strictness remains an operator policy on every deployment target;
# production GCP uses digest-pinned releases by default.
VALIDATOR_BACKEND_IMAGE_POLICY=digest

# SHACL VALIDATOR
# ==============================================================================
# Core SHACL validation is always on and needs no configuration. Everything
# below is OPTIONAL — every knob has a safe default and a hard cap enforced in
# engine code (validibot/validations/validators/shacl/engine.py), so you only
# set these to TIGHTEN a deployment below its defaults.
#
# SHACL_ENABLE_ADVANCED_FEATURES gates the SHACL-AF constructs (author-supplied
# SPARQL constraints + SHACL Rules). It defaults to False because those execute
# SPARQL written by whoever authored the shape. The engine sandboxes them hard —
# network egress (SERVICE/LOAD) and graph mutation (INSERT/DELETE) are rejected,
# triples/depth/time are bounded, and SHACL-JS is always refused — and advanced
# runs happen inside an isolated per-run validator job. It is still a larger
# attack surface than core SHACL, so enabling it is a deliberate, per-deployment
# opt-in for trusted/isolated worker environments. Uncomment to enable.
#SHACL_ENABLE_ADVANCED_FEATURES=True
#
# Resource limits (optional; shown at their defaults). Lower to harden; the
# engine hard-caps each regardless. See docs/dev_docs/how-to/use-shacl-validator.md.
#SHACL_MAX_DATA_TRIPLES=100000
#SHACL_VALIDATION_TIMEOUT_SECONDS=300

# FEATURE TOGGLES
# ==============================================================================
# Registration and login
DJANGO_ACCOUNT_ALLOW_REGISTRATION=true
DJANGO_ACCOUNT_ALLOW_LOGIN=true

# Mount the interactive web app and/or the REST API (both default to true).
# Set ENABLE_APP=false for an API-only deployment, or ENABLE_API=false to serve
# only the web UI. Read in config/settings/base.py; routes gated in
# config/urls_web.py.
ENABLE_APP=true
ENABLE_API=true

# How often (seconds) the run-detail page polls HTMX for run-status updates.
# Default 3; raise to cut UI churn at the cost of slower refresh.
WORKFLOW_RUN_POLL_INTERVAL_SECONDS=3

# RECAPTCHA (optional)
# ==============================================================================
#RECAPTCHA_PUBLIC_KEY=your-recaptcha-public-key
#RECAPTCHA_PRIVATE_KEY=your-recaptcha-private-key

# SIGNUP ABUSE PROTECTIONS
# ==============================================================================
# Both default False. Set to True to reject disposable/throwaway email
# domains at signup and to add a hidden honeypot field to the signup
# form. Some settings modules (e.g. a hosted commercial layer) may
# override these defaults; override here to force an explicit value.
#REJECT_DISPOSABLE_EMAILS=True
#USE_SIGNUP_HONEYPOT=True

# POSTHOG (analytics - optional)
# ==============================================================================
# Set to enable PostHog analytics tracking. Leave empty to disable.
#POSTHOG_PROJECT_KEY=your-posthog-project-key
#POSTHOG_API_HOST=https://us.i.posthog.com

# MFA
# ==============================================================================
# Multi-factor authentication (authenticator apps + recovery codes).
#
# MFA_TOTP_ISSUER is the label shown in users' authenticator apps next to
# their account email. Replace the placeholder below with your deployment
# name (e.g. "Acme Corp Validibot Cloud"). Leaving the placeholder will
# technically work but makes authenticator-app entries indistinguishable
# between deployments.
MFA_TOTP_ISSUER=your-mfa-issuer-name
#
# DJANGO_MFA_ENCRYPTION_KEY is REQUIRED in production — the app refuses
# to start without it. TOTP secrets and recovery-code seeds are stored
# encrypted in the database via Fernet (AES-128-CBC + HMAC-SHA256).
# Without encryption, database read access would let an attacker
# compute any enrolled user's second-factor codes.
#
# Generate a fresh key with:
#
#     python -c "from cryptography.fernet import Fernet; \
#         print(Fernet.generate_key().decode())"
#
# Then store it in GCP Secret Manager alongside DJANGO_SECRET_KEY.
# DO NOT reuse the dev key. DO NOT commit a real key to git.
# See docs/dev_docs/how-to/configure-mfa.md for rotation procedure.
DJANGO_MFA_ENCRYPTION_KEY=replace-with-generated-fernet-key

# DJANGO ALLAUTH
# ==============================================================================
# DJANGO_ADMIN_FORCE_ALLAUTH routes the initial admin sign-in through allauth.
# DJANGO_ADMIN_REQUIRE_MFA then requires every staff or superuser session to
# prove MFA before any admin view runs, including users who had not previously
# enrolled a factor.
#
# Leave both True in production. Set both False only for a short break-glass
# recovery window when allauth itself is broken. A redeploy is required — see
# docs/dev_docs/how-to/configure-mfa.md for the full recovery procedure.
DJANGO_ADMIN_FORCE_ALLAUTH=True
DJANGO_ADMIN_REQUIRE_MFA=True

# ==============================================================================
# ADD-ON CONFIGURATION  —  Pro / Enterprise (self-hosted)
# ==============================================================================
# Everything ABOVE this line is community/core config that every Validibot
# deployment sets. Everything from here down only matters once you install a
# paid tier — a community-only deployment can stop reading here.
#
# These settings are read by the community settings module
# (config.settings.production) but do nothing until the validibot-pro (or
# -enterprise) package is installed to supply the backend that consumes them;
# an empty value means the add-on is off. This section covers:
#
#   * Credential signing / JWKS  (Google Cloud KMS)
#   * MCP server                 (OAuth + service-to-service auth)
#
# The hosted cloud layer adds a further block — see CLOUD-ONLY at the very
# bottom of this file.

# GOOGLE CLOUD KMS (for JWKS / credential signing)
# ==============================================================================
# The signing key for validation credentials.
# Each stage has its own key for isolation:
#   prod:    credential-signing
#   staging: credential-signing-staging
#   dev:     credential-signing-dev
GCP_KMS_SIGNING_KEY="projects/your-project/locations/region/keyRings/your-app-name-keys/cryptoKeys/credential-signing"
# Optional explicit issuer URL for credential payloads. Leave empty to reuse
# SITE_URL.
CREDENTIAL_ISSUER_URL=https://validibot.example.com
# Optional override. ES256 is the only algorithm currently supported.
SIGNING_ALGORITHM=ES256

# OIDC — MCP OAuth support
# ------------------------------------------------------------------------------
# Required when your deployment runs the MCP server and you want
# OAuth-capable MCP clients (Claude Desktop, Cursor, Windsurf, Continue,
# Zed, etc.) to authenticate end users via Dynamic Client Registration.
# Leave blank to disable the OAuth path — the legacy API-token flow
# still works as a fallback for clients that accept a raw bearer token.
#
# Private key PEM, base64-encoded. Used by the Django OIDC provider to
# sign JWT access tokens that the MCP server verifies via JWKS.
# Generate once and back up securely — rotating it invalidates every
# outstanding MCP session. Command:
#   openssl genrsa -out oidc-key.pem 2048 \
#     && base64 < oidc-key.pem | tr -d '\n'
IDP_OIDC_PRIVATE_KEY_B64=<your-base64-encoded-pem>
# Paired secret for the confidential OAuth client the MCP Cloud Run service
# registers with. This and `.mcp`'s VALIDIBOT_OAUTH_CLIENT_SECRET are the two
# Secret Manager-backed copies of the same generated secret, so rotate them
# together from one fresh value. Generate with:
#   openssl rand -hex 32
IDP_OIDC_MCP_SERVER_CLIENT_SECRET=<your-hex-random-secret>

# Public MCP URL: set VALIDIBOT_MCP_BASE_URL once in `.build`. The deploy
# recipe stamps it onto Django web so the OIDC audience and redirect URI are
# derived from the same value MCP uses for its public metadata.

# MCP → Django service-to-service auth (Cloud Run OIDC identity tokens)
# ------------------------------------------------------------------------------
# Every MCP tool call reaches Django via the helper API at
# ``/api/v1/mcp/*``. That API is protected by a two-layer auth check:
#
#   1. Service identity — proves the request came from the MCP Cloud
#      Run service (not a random caller who got hold of a user token).
#   2. End-user identity — resolved from the forwarded
#      X-Validibot-User-Sub / X-Validibot-Api-Token headers that the
#      MCP server attaches after validating the user's OAuth token.
#
# In production on GCP, step 1 uses Cloud Run's built-in OIDC identity token
# flow: the MCP service fetches a Google-signed token whose ``aud`` claim is
# the Django API URL. The GCP deploy recipe stamps that audience onto Django as
# MCP_OIDC_AUDIENCE from VALIDIBOT_MCP_API_BASE_URL in `.build`, so do not
# repeat it here. Django also verifies that the token's service-account email
# is on the MCP_OIDC_ALLOWED_SERVICE_ACCOUNTS list. This mirrors the existing
# TASK_OIDC_* allowlist used for worker/Cloud Tasks auth.
#
# The service-account allowlist is REQUIRED when running MCP on GCP. Django
# refuses to boot (ImproperlyConfigured) if MCP_OIDC_AUDIENCE is stamped by the
# deploy recipe but MCP_OIDC_ALLOWED_SERVICE_ACCOUNTS is empty — an empty
# allowlist would let any Google service account that can mint a token with our
# audience pass the check, which is equivalent to no service identity at all.
#
# (On self-hosted docker-compose deployments, set VALIDIBOT_MCP_SERVICE_KEY
# instead; that path uses a shared secret and skips OIDC entirely.
# See the docker-compose env template.)

# Comma-separated allowlist of service-account emails permitted to
# mint identity tokens for the Django API audience. Must include the
# service account your MCP Cloud Run service runs as (typically
# named ``{app}-mcp-prod@{project}.iam.gserviceaccount.com`` when
# provisioned by ``just gcp mcp setup prod``).
#
#   MCP_OIDC_ALLOWED_SERVICE_ACCOUNTS=validibot-mcp-prod@your-project.iam.gserviceaccount.com
#
# Multiple SAs can be listed, comma-separated (useful when staging
# and prod share one Django deployment, or during a SA migration):
#
#   MCP_OIDC_ALLOWED_SERVICE_ACCOUNTS=validibot-mcp-prod@...,validibot-mcp-staging@...
MCP_OIDC_ALLOWED_SERVICE_ACCOUNTS=

# ==============================================================================
# CLOUD-ONLY  —  hosted SaaS layer
# (read ONLY under DJANGO_SETTINGS_MODULE=validibot_cloud.settings.cloud)
# ==============================================================================
# Everything below is read ONLY when the deployment runs the hosted cloud
# settings module (validibot-cloud editable-installed, EXTRA_UV_EXTRAS=cloud).
# The community module this example defaults to (config.settings.production)
# does NOT read any of it, so a community / self-hosted deploy can ignore this
# whole block. (Other cloud-only knobs such as the LAUNCH_VELOCITY_* runtime
# rate limits also belong under this header.)

# X402 AGENT PAYMENTS (cloud-only)
# ==============================================================================
# x402 is a cloud-only feature — read ONLY under
# DJANGO_SETTINGS_MODULE=validibot_cloud.settings.cloud (community
# config.settings.production does not verify x402). The MCP server no longer
# touches payments, so ALL x402 config now lives here with its single consuming
# service, not in .build. Required only when VALIDIBOT_X402_ENABLED=true.
#
# Enable + test/live switch.
#   VALIDIBOT_X402_ENABLED=true → anonymous paid validation is live.
#   VALIDIBOT_X402_TEST_MODE    → false = mainnet (Base), true = testnet (Base Sepolia).
VALIDIBOT_X402_ENABLED=false
VALIDIBOT_X402_TEST_MODE=false

# Testnet set (used when TEST_MODE=true) — Base Sepolia. The open x402.org
# facilitator needs no CDP auth, so a Sepolia rehearsal needs no CDP key below.
VALIDIBOT_TEST_X402_NETWORK=eip155:84532
VALIDIBOT_TEST_X402_ASSET=0x036cbd53842c5426634e7929541ec2318f3dcf7e
VALIDIBOT_TEST_X402_PAY_TO_ADDRESS=0xYOUR_BASE_SEPOLIA_WALLET
VALIDIBOT_TEST_X402_FACILITATOR_URL=https://x402.org/facilitator

# Mainnet set (used when TEST_MODE=false) — Base. The pay-to address is public
# (quoted in payment requirements); the private key never goes in any env file.
# The facilitator URL has NO default — set it explicitly before enabling live
# x402 (the agent endpoint refuses to settle without it).
VALIDIBOT_X402_NETWORK=eip155:8453
VALIDIBOT_X402_ASSET=0x833589fcd6edb6e08f4c7c32d4f71b54bda02913
VALIDIBOT_X402_PAY_TO_ADDRESS=0xYOUR_BASE_MAINNET_WALLET
VALIDIBOT_X402_FACILITATOR_URL=

# Coinbase CDP facilitator credentials (SECRET, mainnet only). The cloud
# agent-validate endpoint signs a short-lived bearer JWT with this CDP key on
# every /verify and /settle call. Leave blank for a Base Sepolia rehearsal.
# Secret formats: base64 Ed25519 key (current) or PEM EC key (legacy ES256).
#   key id:  organizations/{org}/apiKeys/{key}   (the CDP "key name")
VALIDIBOT_X402_CDP_API_KEY_ID=
VALIDIBOT_X402_CDP_API_KEY_SECRET=

# AUDIT LOG ARCHIVE (GCS, CMEK-encrypted)
# ==============================================================================
# The cloud layer's validibot_cloud.audit_archive app writes gzipped JSONL
# partitions of expired audit-log rows to a dedicated bucket so the table
# stays small and the history survives Cloud SQL. A Django startup check
# (validibot_cloud.audit_archive.E001) refuses to boot — including migrate —
# when AUDIT_ARCHIVE_GCS_BUCKET is empty while the GCS backend is selected
# (which is the cloud default). For a cloud deployment these two are REQUIRED.
#
# The bucket, CMEK key, lifecycle rules, and IAM bindings are provisioned by
# `just gcp audit-archive-setup {stage}` (also run automatically as Step 9 of
# `just gcp init-stage {stage}`). The recipe prints the exact values to paste
# here at the end.
#
# Naming convention: {project}-{app}-audit-archive[-{stage}]
AUDIT_ARCHIVE_GCS_BUCKET=
AUDIT_ARCHIVE_GCS_PROJECT_ID=
# Optional: explicit CMEK key. The bucket default encryption is already set to
# this key by the setup recipe, so leave this commented unless you want the
# backend to pass kms_key_name on every upload.
#AUDIT_ARCHIVE_GCS_KMS_KEY=projects/your-project/locations/region/keyRings/your-app-name-keys/cryptoKeys/audit-archive
# Optional: object-name prefix (default "audit/"). Change only if sharing the
# bucket with other workloads.
#AUDIT_ARCHIVE_GCS_PREFIX=audit/

# STRIPE (cloud billing)  —  Starter Cloud + Pro Cloud products
# ------------------------------------------------------------------------------
# Namespaced VALIDIBOT_CLOUD_STRIPE_* on purpose: validibot-marketing runs a
# SEPARATE Stripe integration with its OWN STRIPE_* vars (different keys,
# different webhook endpoint). The prefix makes the two impossible to confuse.
#
# VALIDIBOT_CLOUD_STRIPE_LIVE_MODE is the master switch: it selects BOTH the key
# set (test vs live) AND the price set below. Flip this one flag at go-live —
# you never swap individual key/price values. Leave False until billing launches.
VALIDIBOT_CLOUD_STRIPE_LIVE_MODE=False

# API keys (restricted `rk_…` keys preferred over full `sk_…`). The TEST_ pair
# is used while LIVE_MODE=False; the LIVE_ pair when True.
VALIDIBOT_CLOUD_STRIPE_TEST_PUBLIC_KEY=pk_test_xxx
VALIDIBOT_CLOUD_STRIPE_TEST_SECRET_KEY=rk_test_xxx
VALIDIBOT_CLOUD_STRIPE_LIVE_PUBLIC_KEY=pk_live_xxx
VALIDIBOT_CLOUD_STRIPE_LIVE_SECRET_KEY=rk_live_xxx

# Webhook signing secrets. SEPARATE endpoint/secret from the marketing site —
# do NOT reuse marketing's whsec_…. An empty secret while LIVE_MODE=True is a
# boot-blocking error (billing.E001); empty in test mode is only a warning.
VALIDIBOT_CLOUD_STRIPE_TEST_WEBHOOK_SECRET=whsec_test_xxx
VALIDIBOT_CLOUD_STRIPE_LIVE_WEBHOOK_SECRET=whsec_live_xxx

# Price IDs — these are `price_…` IDs, NOT product `prod_…` IDs (Stripe checkout
# and the webhook→plan reverse-lookup both key on the price id). Stripe price
# IDs differ between test and live mode, so BOTH sets are listed and LIVE_MODE
# selects the active one. STARTER_CLOUD / PRO_CLOUD are the hosted subscription
# plans; CREDITS_* are the pay-as-you-go credit packs.
VALIDIBOT_CLOUD_STRIPE_TEST_PRICE_STARTER_CLOUD_MONTHLY=price_xxx
VALIDIBOT_CLOUD_STRIPE_TEST_PRICE_PRO_CLOUD_MONTHLY=price_xxx
VALIDIBOT_CLOUD_STRIPE_TEST_PRICE_CREDITS_STARTER_CLOUD=price_xxx
VALIDIBOT_CLOUD_STRIPE_TEST_PRICE_CREDITS_PRO_CLOUD=price_xxx
VALIDIBOT_CLOUD_STRIPE_LIVE_PRICE_STARTER_CLOUD_MONTHLY=price_xxx
VALIDIBOT_CLOUD_STRIPE_LIVE_PRICE_PRO_CLOUD_MONTHLY=price_xxx
VALIDIBOT_CLOUD_STRIPE_LIVE_PRICE_CREDITS_STARTER_CLOUD=price_xxx
VALIDIBOT_CLOUD_STRIPE_LIVE_PRICE_CREDITS_PRO_CLOUD=price_xxx

# RUNTIME LAUNCH VELOCITY LIMITS
# ------------------------------------------------------------------------------
# Per-org rate limits on validation-run launches, enforced by
# validibot_cloud.metering.policies.launch_velocity_policy. Orthogonal to the
# monthly plan quota — this caps SPEED, not total budget. Both have defaults
# (30/min, 500/hour); raise if a legitimate Pro customer hits the limit, tighten
# if abuse emerges.
LAUNCH_VELOCITY_PER_MINUTE=30
LAUNCH_VELOCITY_PER_HOUR=500
