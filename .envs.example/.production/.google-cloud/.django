# Validibot GCP Configuration
# ==============================================================================
# Copy this file to .envs/.production/.google-cloud/.django
# This file is for Google Cloud Platform deployments (Cloud Run).

# Environment identifier
VALIDIBOT_STAGE=prod

# DJANGO
# ==============================================================================
DJANGO_SETTINGS_MODULE=config.settings.production
DEPLOYMENT_TARGET=gcp
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=your-secret-key-here-change-this
# IMPORTANT: Change to a random URL to prevent automated attacks on /admin/.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(16))"
DJANGO_ADMIN_URL=admin/
# Specific Cloud Run hostnames plus custom domain
# Security: Do NOT use wildcards like .run.app - that allows any Cloud Run service
DJANGO_ALLOWED_HOSTS=your-service-name.region.run.app,validibot.example.com
# Generate a secret key with:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'

# Security settings for production
SECURE_PROXY_SSL_HEADER=('HTTP_X_FORWARDED_PROTO','https')

# DATABASE
# ==============================================================================
# Cloud SQL uses Unix socket connection via Cloud SQL Auth Proxy
# Format: postgres://USER:PASSWORD@/DATABASE?host=/cloudsql/CONNECTION_NAME
POSTGRES_DB=validibot
POSTGRES_USER=validibot_user
POSTGRES_PASSWORD=change-this-password
CLOUD_SQL_CONNECTION_NAME=your-project:region:your-instance

DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@/${POSTGRES_DB}?host=/cloudsql/${CLOUD_SQL_CONNECTION_NAME}

# CACHE (shared across workers + scaled instances)
# ==============================================================================
# Django's cache must be shared across Gunicorn workers and Cloud Run
# instances — allauth rate limiting and TOTP replay prevention depend
# on it. The GCP deployment uses Django's `DatabaseCache` backend by
# default (persisted in the existing Cloud SQL Postgres database);
# that's $0 incremental cost and fine for pre-release volume.
#
# Before the first deploy, run `python manage.py createcachetable` to
# provision the `django_cache` table. See the runbook for details.
#
# When traffic grows or latency becomes a concern, provision Memorystore
# for Redis, attach it via VPC connector, and uncomment REDIS_URL below.
# `config/settings/production.py` will switch to RedisCache automatically.
#REDIS_URL=redis://10.x.x.x:6379/0

# Cache key prefix — required when the Redis instance is shared with
# other environments (e.g. staging + prod behind the same managed
# Redis, or dev environments sharing a single Memorystore instance
# to save on cost). Django transparently prepends this to every
# cache key; without it, keys collide silently across environments
# and a staging org's plan mask can leak into production. Safe to
# leave unset when Redis is single-tenant to this deployment —
# Django will log a warning on boot if it looks risky.
#DJANGO_CACHE_KEY_PREFIX=prod

# LOGGING
# ==============================================================================
# Sentry error tracking (recommended for production)
#SENTRY_DSN=https://your-sentry-dsn

# STORAGE (GCS)
# ==============================================================================
# On Cloud Run, ADC uses the service account attached to the Cloud Run service.
# Locally, run `gcloud auth application-default login` first.
#
# Single bucket with prefix-based separation:
#   public/  - Public files (avatars, images) - configure IAM for allUsers read
#   private/ - Private files (submissions, validation data)
STORAGE_BUCKET=your-app-name-storage

# ADD-ON CONFIGURATION
# ==============================================================================
# Commercial add-ons installed on top of community define their own env
# vars (e.g. audit-log archiving to object storage, runtime rate limits).
# Consult each add-on's own documentation for the keys it expects; a
# community-only deployment does not need any of them.

# DEFAULT USERS
# ==============================================================================
# Initial superuser created on first run
SUPERUSER_USERNAME=admin
SUPERUSER_PASSWORD=change-this-password
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_NAME=Admin User

# EMAIL
# ==============================================================================
# From address for transactional emails. Change to your domain.
DJANGO_DEFAULT_FROM_EMAIL=Validibot <noreply@your-domain.com>
# If not configured, emails are logged to console.
# Postmark (recommended):
#POSTMARK_SERVER_TOKEN=your-postmark-server-token

# URLS
# ==============================================================================
SITE_URL=https://validibot.example.com
WORKER_URL=https://your-worker-service.region.run.app

# GCP
# ==============================================================================
# Resource names follow the pattern: {GCP_APP_NAME}-{resource}[-{stage}]
# where GCP_APP_NAME is set in .envs/.production/.google-cloud/.just
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-west1

# Cloud Tasks
GCS_TASK_QUEUE_NAME=your-app-name-tasks
CLOUD_TASKS_SERVICE_ACCOUNT=your-app-name-cloudrun-prod@your-project.iam.gserviceaccount.com

# Worker-endpoint OIDC verification (validators, Cloud Tasks, Cloud Scheduler).
# See docs/dev_docs/deployment/environment-configuration.md and
# ADR-2026-04-18 for the full design.
#
# TASK_OIDC_AUDIENCE: Expected `aud` claim. Must equal the worker service
# URL origin (scheme + host, NO path). Cloud Tasks and Cloud Scheduler sign
# tokens with this exact value, and validator containers derive it from the
# callback URL's origin. If unset, Django falls back to WORKER_URL.
# Typical value (same as WORKER_URL above):
TASK_OIDC_AUDIENCE=https://your-worker-service.region.run.app
#
# TASK_OIDC_ALLOWED_SERVICE_ACCOUNTS: Comma-separated list of service
# account emails authorised to sign tokens for worker endpoints. EMPTY LIST
# MEANS REJECT EVERYTHING. Django raises ImproperlyConfigured on startup
# when DEPLOYMENT_TARGET=gcp and this list is empty. Include every SA that
# invokes the worker: the main Cloud Run SA (used by Cloud Tasks + Cloud
# Scheduler + validator Cloud Run Jobs). Add per-stage SAs as needed.
TASK_OIDC_ALLOWED_SERVICE_ACCOUNTS=your-app-name-cloudrun-prod@your-project.iam.gserviceaccount.com

# Validation infrastructure (Cloud Run Jobs)
GCS_VALIDATION_BUCKET=your-app-name-storage
GCS_WEATHER_DATA_DIR=weather_data
GCS_ENERGYPLUS_JOB_NAME=your-app-name-validator-energyplus
GCS_FMU_JOB_NAME=your-app-name-validator-fmu

# FEATURE TOGGLES
# ==============================================================================
# Registration and login
DJANGO_ACCOUNT_ALLOW_REGISTRATION=true
DJANGO_ACCOUNT_ALLOW_LOGIN=true

# GOOGLE CLOUD KMS (for JWKS / credential signing)
# ==============================================================================
# The signing key for validation credentials.
# Each stage has its own key for isolation:
#   prod:    credential-signing
#   staging: credential-signing-staging
#   dev:     credential-signing-dev
GCP_KMS_SIGNING_KEY="projects/your-project/locations/region/keyRings/your-app-name-keys/cryptoKeys/credential-signing"
# Optional explicit issuer URL for credential payloads. Leave empty to reuse
# SITE_URL.
CREDENTIAL_ISSUER_URL=https://validibot.example.com
# Optional override. ES256 is the only algorithm currently supported.
SIGNING_ALGORITHM=ES256

# RECAPTCHA (optional)
# ==============================================================================
#RECAPTCHA_PUBLIC_KEY=your-recaptcha-public-key
#RECAPTCHA_PRIVATE_KEY=your-recaptcha-private-key

# SIGNUP ABUSE PROTECTIONS
# ==============================================================================
# Both default False. Set to True to reject disposable/throwaway email
# domains at signup and to add a hidden honeypot field to the signup
# form. Some settings modules (e.g. a hosted commercial layer) may
# override these defaults; override here to force an explicit value.
#REJECT_DISPOSABLE_EMAILS=True
#USE_SIGNUP_HONEYPOT=True

# POSTHOG (analytics - optional)
# ==============================================================================
# Set to enable PostHog analytics tracking. Leave empty to disable.
#POSTHOG_PROJECT_KEY=your-posthog-project-key
#POSTHOG_API_HOST=https://us.i.posthog.com

# MFA
# ------------------------------------------------------------------------------
# Multi-factor authentication (authenticator apps + recovery codes).
#
# MFA_TOTP_ISSUER is the label shown in users' authenticator apps next to
# their account email. Replace the placeholder below with your deployment
# name (e.g. "Acme Corp Validibot Cloud"). Leaving the placeholder will
# technically work but makes authenticator-app entries indistinguishable
# between deployments.
MFA_TOTP_ISSUER=your-mfa-issuer-name
#
# DJANGO_MFA_ENCRYPTION_KEY is REQUIRED in production — the app refuses
# to start without it. TOTP secrets and recovery-code seeds are stored
# encrypted in the database via Fernet (AES-128-CBC + HMAC-SHA256).
# Without encryption, database read access would let an attacker
# compute any enrolled user's second-factor codes.
#
# Generate a fresh key with:
#
#     python -c "from cryptography.fernet import Fernet; \
#         print(Fernet.generate_key().decode())"
#
# Then store it in GCP Secret Manager alongside DJANGO_SECRET_KEY.
# DO NOT reuse the dev key. DO NOT commit a real key to git.
# See docs/dev_docs/how-to/configure-mfa.md for rotation procedure.
DJANGO_MFA_ENCRYPTION_KEY=replace-with-generated-fernet-key
#
# DJANGO_ADMIN_FORCE_ALLAUTH routes Django's built-in /admin/login/ view
# through the django-allauth authentication flow, so that admin sign-in
# inherits allauth's rate limiting, session rotation, and — most
# importantly — MFA enforcement on users who have enrolled a second
# factor. Without this flag, admin logs in via a plain Django form that
# bypasses allauth entirely, meaning a staff user with MFA configured
# can still enter the admin with only a password.
#
# Leave this True in production. Flip to False ONLY as a break-glass
# when allauth itself is broken (e.g. a bad MFA key, a corrupted
# Authenticator row the `clear_mfa` management command can't fix from
# a Cloud Run Job). A redeploy is required for the change to take
# effect — see docs/dev_docs/how-to/configure-mfa.md for the full
# recovery procedure.
DJANGO_ADMIN_FORCE_ALLAUTH=True

# OIDC — MCP OAuth support
# ------------------------------------------------------------------------------
# Required when your deployment runs the MCP server and you want
# OAuth-capable MCP clients (Claude Desktop, Cursor, Windsurf, Continue,
# Zed, etc.) to authenticate end users via Dynamic Client Registration.
# Leave blank to disable the OAuth path — the legacy API-token flow
# still works as a fallback for clients that accept a raw bearer token.
#
# Private key PEM, base64-encoded. Used by the Django OIDC provider to
# sign JWT access tokens that the MCP server verifies via JWKS.
# Generate once and back up securely — rotating it invalidates every
# outstanding MCP session. Command:
#   openssl genrsa -out oidc-key.pem 2048 \
#     && base64 < oidc-key.pem | tr -d '\n'
IDP_OIDC_PRIVATE_KEY_B64=<your-base64-encoded-pem>
# Shared secret for the confidential OAuth client the MCP Cloud Run
# service registers with. Must be identical to the value in
# .envs/<stage>/.google-cloud/.mcp's VALIDIBOT_OAUTH_CLIENT_SECRET so
# both sides of the token exchange agree. Generate with:
#   openssl rand -hex 32
IDP_OIDC_MCP_SERVER_CLIENT_SECRET=<your-hex-random-secret>

# Public URL of YOUR MCP server. This one variable drives both
# Django's OIDC audience claim ({BASE}/mcp, stamped onto tokens) and
# the confidential client's registered redirect URI
# ({BASE}/auth/callback), so both sides of the OAuth flow stay in
# lockstep. There is no default — set this to wherever your MCP Cloud
# Run service is reachable:
#
#   VALIDIBOT_MCP_BASE_URL=https://mcp.your-domain.example
VALIDIBOT_MCP_BASE_URL=


# MCP → Django service-to-service auth (Cloud Run OIDC identity tokens)
# ------------------------------------------------------------------------------
# Every MCP tool call reaches Django via the helper API at
# ``/api/v1/mcp/*``. That API is protected by a two-layer auth check:
#
#   1. Service identity — proves the request came from the MCP Cloud
#      Run service (not a random caller who got hold of a user token).
#   2. End-user identity — resolved from the forwarded
#      X-Validibot-User-Sub / X-Validibot-Api-Token headers that the
#      MCP server attaches after validating the user's OAuth token.
#
# In production on GCP, step 1 uses Cloud Run's built-in OIDC identity
# token flow: the MCP service fetches a Google-signed token whose
# ``aud`` claim equals MCP_OIDC_AUDIENCE (below), and Django verifies
# both the signature and that the token's service-account email is on
# the MCP_OIDC_ALLOWED_SERVICE_ACCOUNTS list. This mirrors the
# existing TASK_OIDC_* allowlist used for worker/Cloud Tasks auth.
#
# Both settings are REQUIRED together when running MCP on GCP:
# Django refuses to boot (ImproperlyConfigured) if MCP_OIDC_AUDIENCE is
# set but MCP_OIDC_ALLOWED_SERVICE_ACCOUNTS is empty — an empty
# allowlist would let any Google service account that can mint a
# token with our audience pass the check, which is equivalent to no
# service identity at all.
#
# (On self-hosted docker-compose deployments, set VALIDIBOT_MCP_SERVICE_KEY
# instead; that path uses a shared secret and skips OIDC entirely.
# See the docker-compose env template.)

# Audience Cloud Run stamps onto identity tokens the MCP service mints
# for Django calls. By convention the audience is the public URL of
# the service being called — set this to your Django hostname:
#
#   MCP_OIDC_AUDIENCE=https://app.your-domain.example
MCP_OIDC_AUDIENCE=

# Comma-separated allowlist of service-account emails permitted to
# mint identity tokens for the audience above. Must include the
# service account your MCP Cloud Run service runs as (typically
# named ``{app}-mcp-prod@{project}.iam.gserviceaccount.com`` when
# provisioned by ``just gcp mcp setup prod``).
#
#   MCP_OIDC_ALLOWED_SERVICE_ACCOUNTS=validibot-mcp-prod@your-project.iam.gserviceaccount.com
#
# Multiple SAs can be listed, comma-separated (useful when staging
# and prod share one Django deployment, or during a SA migration):
#
#   MCP_OIDC_ALLOWED_SERVICE_ACCOUNTS=validibot-mcp-prod@...,validibot-mcp-staging@...
MCP_OIDC_ALLOWED_SERVICE_ACCOUNTS=
