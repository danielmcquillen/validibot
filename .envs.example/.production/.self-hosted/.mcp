# Environment variables for the self-hosted MCP container.
#
# Copy this file to .envs/.production/.self-hosted/.mcp and fill in
# the values that apply to your deployment. The MCP service only runs
# when ``ENABLE_MCP_SERVER=true`` is set at ``just self-hosted up`` —
# see validibot/just/self-hosted/mod.just.
#
# All variables are read by the FastMCP server at
# validibot/mcp/src/validibot_mcp/config.py.

# ── Required ───────────────────────────────────────────────────────────

# The Validibot REST API the MCP server forwards tool calls to. On a
# self-hosted deployment this is usually the internal service URL,
# e.g. http://web:8000 (or the externally reachable URL if you prefer).
VALIDIBOT_API_BASE_URL=http://web:8000

# The public URL of this MCP server, used for RFC 9728 metadata and as
# the default OAuth audience root. Set this to whatever hostname your
# reverse proxy terminates TLS at. Keep it identical to
# VALIDIBOT_MCP_BASE_URL in `.django` so the OIDC audience + redirect URI
# line up on both sides.
VALIDIBOT_MCP_BASE_URL=https://mcp.your-domain.example

# Upstream OAuth authorization server. In most self-hosted deployments
# this is the same Django instance as the API.
VALIDIBOT_OAUTH_AUTHORIZATION_SERVER_URL=https://app.your-domain.example

# ── Kill switch ────────────────────────────────────────────────────────
# Set to ``false`` to have the MCP server return 503 on every tool call
# without restarting the container. Useful for incidents.
VALIDIBOT_MCP_ENABLED=true

# ── Service-to-service auth ────────────────────────────────────────────
# The MCP server authenticates to the Validibot REST API using this shared
# secret on the ``X-MCP-Service-Key`` header. Generate one value and place that
# paired secret here and in `.django` (where Django exposes it as the
# ``MCP_SERVICE_KEY`` setting). A mismatch returns 401 on every /api/v1/mcp/*
# call.
VALIDIBOT_MCP_SERVICE_KEY=replace-me-with-a-long-random-string

# ── OAuth client credentials (optional) ────────────────────────────────
# If you configure OAuth for MCP clients (Claude Desktop), the MCP
# server needs its own confidential client registered with the Django
# OIDC provider. Leaving these blank falls back to the legacy API-token
# flow, which is simpler but does not interop with Claude Desktop's
# Dynamic Client Registration.
#
# Paired OAuth secret: if you set VALIDIBOT_OAUTH_CLIENT_SECRET, use the same
# generated value for IDP_OIDC_MCP_SERVER_CLIENT_SECRET in `.django`. These are
# the two runtime copies of one confidential OIDC client secret. Generate with
# `openssl rand -hex 32`.
# VALIDIBOT_OAUTH_CLIENT_ID=validibot-mcp-server
# VALIDIBOT_OAUTH_CLIENT_SECRET=

# Validibot's authorize/token/revoke/JWKS paths are derived locally from the
# authorization-server URL, avoiding a discovery-network request at startup.
# If a compatible provider is routed differently, override complete URLs here:
# VALIDIBOT_OAUTH_AUTHORIZATION_ENDPOINT=https://app.your-domain.example/oauth/authorize
# VALIDIBOT_OAUTH_TOKEN_ENDPOINT=https://app.your-domain.example/oauth/token
# VALIDIBOT_OAUTH_REVOCATION_ENDPOINT=https://app.your-domain.example/oauth/revoke
# VALIDIBOT_OAUTH_JWKS_URL=https://app.your-domain.example/oauth/jwks
