# Validibot Caddy reverse proxy configuration
#
# This Caddyfile is read by the optional ``caddy`` Compose service in
# docker-compose.production.yml. It is OFF by default — see
# ADR-2026-04-27 section 21 for why. To enable:
#
#   COMPOSE_PROFILES=caddy just self-hosted deploy
#
# Caddy automatically issues a Let's Encrypt certificate for the
# hostname declared in the SITE_URL env variable, which the Compose
# service passes through from .envs/.production/.self-hosted/.django.
# That hostname must already resolve to this VM's public IP — run
# ``./deploy/self-hosted/scripts/check-dns`` to verify before starting
# Caddy.
#
# If you don't already have an account email registered for ACME
# challenges, set ACME_EMAIL in your shell or .env file before bringing
# the stack up. Caddy will use it to receive Let's Encrypt expiry
# notifications.

# Caddy interpolates {$SITE_URL} from the environment. If SITE_URL is
# https://validibot.example.com, Caddy will:
#   - terminate TLS for validibot.example.com (port 443)
#   - redirect port 80 traffic to HTTPS automatically
#   - proxy all requests to the web container on port 8000
{$SITE_URL} {
    # Proxy to the Django web container. Compose puts both Caddy and
    # ``web`` on the validibot bridge network, so the hostname ``web``
    # resolves to the web service.
    reverse_proxy web:8000

    # Trust the X-Forwarded-* headers Caddy itself sets, so Django
    # honours the original client IP for rate limiting and audit logs.
    # Caddy sets these by default; this is just here as a reminder for
    # operators reading the file.

    # Optional: tighten security headers.
    header {
        # HSTS: tell browsers to use HTTPS for this hostname for 1 year.
        # Remove if you're still testing certificate issuance and don't
        # want browsers to cache the HSTS policy.
        Strict-Transport-Security "max-age=31536000; includeSubDomains"

        # Defense-in-depth — Django sets these too, but Caddy is the
        # outer envelope.
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"

        # Hide the Caddy server header.
        -Server
    }

    # Health check endpoint exposed by Django. Caddy uses this for its
    # own healthcheck, but operators can also curl it directly.
    handle /health/ {
        reverse_proxy web:8000
    }
}

# If you operate multiple Validibot hostnames behind the same Caddy
# instance (e.g. app.example.com + mcp.example.com), duplicate the
# block above with the second hostname and the appropriate
# reverse_proxy target. Out of scope for the canonical single-VM
# deployment.
