msgstr "Valida payloads JSON contra un esquema JSON proporcionado por el autor del flujo de trabajo."

#: validibot/validations/utils/__init__.py:55
msgid ""
"\n"
"                <p>\n"
"                This validator validates JSON payloads against a predefined JSON schema.\n"
"                When a workflow author selects this validator, they must attach\n"
"                a valid JSON schema.\n"
"                </p>\n"
"                "
msgstr ""
"\n"
"                <p>\n"
"                Este validador valida payloads JSON contra un esquema JSON predefinido.\n"
"                Cuando un autor del flujo de trabajo selecciona este validador, debe adjuntar\n"
"                un esquema JSON válido.\n"
"                </p>\n"
"                "

