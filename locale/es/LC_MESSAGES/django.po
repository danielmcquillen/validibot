msgstr ""
"Definición de conjunto de reglas en línea (por ejemplo, texto de esquema JSON o XML). Úselo cuando prefiera pegar o almacenar las reglas sin subir un archivo."

msgid "Additional metadata about the ruleset (non-rule data only)."
msgstr "Metadatos adicionales sobre el conjunto de reglas (solo datos que no son reglas)."

msgid "Provide rules either as text or file, not both."
msgstr "Proporcione las reglas como texto o archivo, no ambos."

msgid "XML schema rulesets must define metadata['schema_type']."
msgstr "Los conjuntos de reglas de esquema XML deben definir metadata['schema_type']."

#, python-format
msgid "Schema type '%(st)s' is not valid for %(rt)s."
msgstr "El tipo de esquema '%(st)s' no es válido para %(rt)s."

msgid "JSON schema rulesets must define metadata['schema_type']."
msgstr "Los conjuntos de reglas de esquema JSON deben definir metadata['schema_type']."

msgid ""
"Schema rulesets must include either inline rules text or an uploaded file."
msgstr ""
"Los conjuntos de reglas de esquema deben incluir texto de reglas en línea o un archivo subido."

msgid "Structured operator used for BASIC assertions."
msgstr "Operador estructurado usado para aserciones BASIC."

msgid "Reference to a catalog entry when targeting a known signal."
msgstr "Referencia a una entrada de catálogo cuando se apunta a una señal conocida."

msgid "Custom JSON-style path for validators that allow free-form targets."
msgstr "Ruta de estilo JSON personalizada para validadores que permiten objetivos de forma libre."

msgid "Optional CEL expression gating when the assertion evaluates."
msgstr "Expresión CEL opcional que condiciona cuándo se evalúa la aserción."

msgid "Operator payload (values, range bounds, regex pattern, etc.)."
msgstr "Payload del operador (valores, límites de rango, patrón de expresión regular, etc.)."

msgid ""
"Operator options (inclusive bounds, tolerance metadata, case folding, etc.)."
msgstr ""
"Opciones del operador (límites inclusivos, metadatos de tolerancia, plegado de mayúsculas, etc.)."

msgid "Message rendered when the assertion fails."
msgstr "Mensaje mostrado cuando la aserción falla."

msgid "Message rendered when the assertion passes."
msgstr "Mensaje mostrado cuando la aserción se aprueba."

msgid "Normalized CEL preview generated from the stored payload."
msgstr "Vista previa CEL normalizada generada desde el payload almacenado."

msgid "Schema version for `rhs` and `options` payloads."
msgstr "Versión de esquema para los payloads `rhs` y `options`."

msgid "Provide either a catalog target or a custom path (but not both)."
msgstr "Proporcione un objetivo de catálogo o una ruta personalizada (pero no ambos)."

