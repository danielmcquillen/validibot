msgstr "nombre-en-slug"

msgid ""
"Signal name must be unique across inputs and outputs for this validator."
msgstr ""
"El nombre de la señal debe ser único entre entradas y salidas de este validador."

#, python-format
msgid "File type '.%(ext)s' is not allowed. Accepted: %(allowed)s."
msgstr "El tipo de archivo '.%(ext)s' no está permitido. Aceptados: %(allowed)s."

#, python-format
msgid "File is too large (max %(max)s MB)."
msgstr "El archivo es demasiado grande (máx. %(max)s MB)."

msgid "This file appears to be a binary archive or executable."
msgstr "Este archivo parece ser un archivo comprimido binario o ejecutable."

#, python-format
msgid "File content does not match expected format for %(type)s."
msgstr "El contenido del archivo no coincide con el formato esperado para %(type)s."

msgid ""
"Username or email of the user (defaults to current user or first available)"
msgstr "Nombre de usuario o correo electrónico (por defecto el usuario actual o el primero disponible)"

msgid "The user who created this ruleset."
msgstr "El usuario que creó este conjunto de reglas."

msgid "Type of validation ruleset, e.g. 'json_schema', 'xml_schema'"
msgstr "Tipo de conjunto de reglas de validación, p. ej. 'json_schema', 'xml_schema'"

msgid ""
"Optional uploaded file containing the ruleset definition. Leave empty when "
