#: validibot/validations/utils/__init__.py:26
msgid "Basic Validator"
msgstr "基本バリデーター"

#: validibot/validations/utils/__init__.py:29
msgid "The simplest validator. Allows workflow author to add signals and assertions directly without a validator catalog."
msgstr "最もシンプルなバリデーターです。ワークフロー作成者はバリデーターカタログなしでシグナルとアサーションを直接追加できます。"

#: validibot/validations/utils/__init__.py:34
msgid ""
"\n"
"                <p>Workflow authors can use the 'Basic Validator' as a starting point\n"
"                for creating assertions directly. There are no signals\n"
"                or predefined assertions.\n"
"                Perfect for lightweight checks or ad-hoc rules expressed in CEL.</p>\n"
"                "
msgstr ""
"\n"
"                <p>ワークフロー作成者は「基本バリデーター」をアサーションを直接作成する出発点として使用できます。\n"
"                シグナルや定義済みアサーションはありません。\n"
"                CELで表現した軽量チェックやアドホックルールに最適です。</p>\n"
"                "

#: validibot/validations/utils/__init__.py:48
msgid "JSON Schema Validator"
msgstr "JSONスキーマバリデーター"

#: validibot/validations/utils/__init__.py:51
msgid "Validate JSON payloads against a JSON schema provided by the workflow author."
msgstr "ワークフロー作成者が提供するJSONスキーマに対してJSONペイロードを検証します。"

#: validibot/validations/utils/__init__.py:55
msgid ""
"\n"
"                <p>\n"
"                This validator validates JSON payloads against a predefined JSON schema.\n"
"                When a workflow author selects this validator, they must attach\n"
"                a valid JSON schema.\n"
"                </p>\n"
"                "
msgstr ""
"\n"
"                <p>\n"
"                このバリデーターは、事前定義されたJSONスキーマに対してJSONペイロードを検証します。\n"
"                ワークフロー作成者がこのバリデーターを選択する場合、\n"
"                有効なJSONスキーマを添付する必要があります。\n"
"                </p>\n"
"                "

#: validibot/validations/utils/__init__.py:68
msgid "XML Validator"
msgstr "XMLバリデーター"

#: validibot/validations/utils/__init__.py:71
msgid "Validate XML submissions against a XSD, DTD, or RelaxNG schema provided by the workflow author."
msgstr "ワークフロー作成者が提供するXSD、DTD、またはRelaxNGスキーマに対してXML提出物を検証します。"

#: validibot/validations/utils/__init__.py:75
msgid ""
"\n"
"                <p>\n"
"                This validator validates XML submissions against an XSD, DTD\n"
"                or RelaxNG schema.\n"
"                When a workflow author selects this validator, they must attach\n"
"                a valid schema.\n"
"                </p>\n"
"                "
msgstr ""
"\n"
"                <p>\n"
"                このバリデーターは、XSD、DTD、\n"
"                またはRelaxNGスキーマに対してXML提出物を検証します。\n"
"                ワークフロー作成者がこのバリデーターを選択する場合、\n"
"                有効なスキーマを添付する必要があります。\n"
"                </p>\n"
"                "

#: validibot/validations/utils/__init__.py:89
msgid "EnergyPlus™ Validator"
msgstr "EnergyPlus™ バリデーター"

#: validibot/validations/utils/__init__.py:92
msgid "Validate EnergyPlus IDF files and outputs."
msgstr "EnergyPlus IDFファイルと出力を検証します。"

#: validibot/validations/utils/__init__.py:95
msgid ""
"\n"
"                <p>Validate EnergyPlus IDF files for correctness and expected outputs.\n"
"                Run simulations, surface findings, and keep building models\n"
"                reliable.</p>\n"
"                "
msgstr ""
"\n"
"                <p>EnergyPlus IDFファイルの正確性と期待される出力を検証します。\n"
"                シミュレーションを実行して結果を確認し、建物モデルの\n"
"                信頼性を維持します。</p>\n"
"                "

#: validibot/validations/utils/__init__.py:111
msgid "Run FMUs and assert against inputs and outputs."
msgstr "FMUを実行し、入出力に対してアサーションを行います。"

#: validibot/validations/utils/__init__.py:114
msgid ""
"\n"
"                <p>\n"
"                This validator allows a workflow author to write assertions\n"
"                against incoming data.\n"
"                It allows a workflow author to validating incoming data as\n"
"                well as simulation outputs.\n"
"                </p>\n"
"                <p>\n"
"                The validator sends inputs using the Functional Mock-up Interface (FMI)\n"
"                standard to an\n"
"                FMU-based simulation running in an isolated runtime. If the\n"
"                simulation succeeds it\n"
"                gathers outputs and returns them as output signals for further\n"
"                validation, if defined.\n"
"                </p>\n"
"                <p>\n"
"                The workflow author to write assertions against simulation\n"
"                output signals.\n"
"                </p>\n"
"                "
msgstr ""
"\n"
"                <p>\n"
"                このバリデーターにより、ワークフロー作成者は受信データに対して\n"
"                アサーションを記述できます。\n"
"                受信データとシミュレーション出力の両方を\n"
"                検証できます。\n"
"                </p>\n"
"                <p>\n"
"                バリデーターは、Functional Mock-up Interface（FMI）\n"
"                標準を使用して入力を\n"
"                隔離されたランタイムで実行されるFMUベースのシミュレーションに送信します。シミュレーションが\n"
"                成功すると、\n"
"                出力を収集し、定義されている場合はさらなる\n"
"                検証のための出力シグナルとして返します。\n"
"                </p>\n"
"                <p>\n"
"                ワークフロー作成者はシミュレーション\n"
"                出力シグナルに対するアサーションを記述できます。\n"
"                </p>\n"
"                "

#: validibot/validations/utils/__init__.py:143
msgid "AI Assisted Validator"
msgstr "AI支援バリデーター"

#: validibot/validations/utils/__init__.py:146
msgid "Use AI to validate submission content against your criteria."
msgstr "AIを使用して、お客様の基準に対して提出コンテンツを検証します。"

#: validibot/validations/utils/__init__.py:149
msgid ""
"\n"
"                <p>Use AI to validate submission content against your criteria. Blend\n"
"                traditional assertions with AI scoring to review nuanced data quickly.\n"
"                </p>\n"
"                "
msgstr ""
"\n"
"                <p>AIを使用して、お客様の基準に対して提出コンテンツを検証します。従来の\n"
"                アサーションとAIスコアリングを組み合わせて、複雑なデータを素早く確認します。\n"
"                </p>\n"
"                "

#: validibot/validations/utils/__init__.py:162
msgid "THERM Validator"
msgstr "THERMバリデーター"

#: validibot/validations/utils/__init__.py:165
msgid "Validate THERM thermal analysis files (THMX/THMZ) for geometry, materials, and boundary conditions."
msgstr "形状、材料、境界条件についてTHERM熱解析ファイル（THMX/THMZ）を検証します。"

#: validibot/validations/utils/__init__.py:169
msgid ""
"\n"
"                <p>Validate LBNL THERM files before submission to NFRC or\n"
"                other certification bodies. Checks geometry closure, material\n"
"                property ranges, boundary condition completeness, and\n"
"                reference integrity. Extracts signals for downstream\n"
"                compliance assertions (e.g. NFRC 100 winter conditions).</p>\n"
"                "
msgstr ""
"\n"
"                <p>NFRCや他の認証機関への提出前にLBNL THERMファイルを検証します。\n"
"                形状の閉合性、材料\n"
"                特性値の範囲、境界条件の完全性、\n"
"                参照整合性を確認します。下流の\n"
"                コンプライアンスアサーション（例：NFRC 100冬条件）のシグナルを抽出します。</p>\n"
"                "

#: validibot/validations/validators/base/advanced.py:196
#, python-format
