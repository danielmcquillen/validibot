{
  "name": "validibot-static",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "sass --style=compressed --quiet-deps --load-path=node_modules --load-path=validibot/static/src/scss validibot/static/src/scss/project.scss:validibot/static/css/project.css && node -e \"require('fs').appendFileSync('validibot/static/css/project.css.map', '\\n')\"",
    "build:js": "esbuild validibot/static/src/ts/project.ts validibot/static/src/ts/headInit.ts --bundle --minify --sourcemap --outdir=validibot/static/js",
    "watch": "npm run watch:css & npm run watch:js",
    "watch:css": "sass --watch --quiet-deps --load-path=node_modules validibot/static/src/scss/project.scss:validibot/static/css/project.css",
    "watch:js": "esbuild validibot/static/src/ts/project.ts validibot/static/src/ts/headInit.ts --bundle --sourcemap --outdir=validibot/static/js --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/bootstrap": "^5.2.10",
    "esbuild": "^0.28.1",
    "jsdom": "^25.0.1",
    "sass": "latest",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "bootstrap": "^5.3.7",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.4.6",
    "htmx.org": "^2.0.6"
  },
  "comment:overrides": "Force every transitive esbuild to the patched line (>=0.28.1) to close GHSA-g7r4-m6w7-qqqr, which affects esbuild's dev server <0.28.1. Only vitest's nested vite pulled the vulnerable 0.27.x; $esbuild keeps it pinned to our single direct esbuild spec above.",
  "overrides": {
    "esbuild": "$esbuild"
  }
}
